@require './code-theme'

//***vdoing主题-变量***//

// 颜色

$bannerTextColor = #fff // 首页banner区(博客标题)文本颜色
$accentColor = #11A8CD
$activeColor = #ff5722
$arrowBgColor = #ccc
$badgeTipColor = #42b983
$badgeWarningColor = darken(#ffe564, 35%)
$badgeErrorColor = #DA5961

// 布局
$navbarHeight = 3.6rem
$sidebarWidth = 18rem
$contentWidth = 860px
$homePageWidth = 1100px
$rightMenuWidth = 230px // 右侧菜单

// 代码块
$lineNumbersWrapperWidth = 2.5rem

.code-group-item.active
  display: block !important

// 加粗字体颜色
strong
  // color 
  color #00A55A

// 浅色模式
.theme-mode-light
  --bodyBg: #f4f4f4
  --mainBg: rgba(255,255,255,1)
  --sidebarBg: rgba(255,255,255,.8)
  --blurBg: rgba(255,255,255,.9)
  --customBlockBg: #f1f1f1
  --textColor: #00323c
  --textLightenColor: #d63200
  --borderColor: rgba(0,0,0,.15)
  --codeBg: #ecf4fa
  --codeColor: #525252
  codeThemeLight()

// 深色模式
.theme-mode-dark
  --bodyBg: rgba(40,40,56,1)
  --mainBg: rgba(40,40,56,1)
  --sidebarBg: rgba(40,40,56,.8)
  --blurBg: rgba(40,40,56,.9)
  --customBlockBg: rgba(25,25,49,0.53)
  --textColor: #acb7c4
  --textLightenColor: #F9D923
  --borderColor: #1d1d26
  --codeBg: #282c34
  --codeColor: #D4D4D4
  codeThemeDark()

// 阅读模式
.theme-mode-read
  --bodyBg: rgb(236,236,204)
  --mainBg: rgba(245,245,213,1)
  --sidebarBg: rgba(245,245,213,.8)
  --blurBg: rgba(245,245,213,.9)
  --customBlockBg: rgb(236,236,204)
  --textColor: #704214
  --textLightenColor: #996633
  --borderColor: rgba(0,0,0,.15)
  --codeBg: #FCFFE7
  --codeColor: #525252
  codeThemeLight()
   // 行高亮颜色
  div[class*="language-"]
    .highlight-lines
      .highlighted
        background-color rgba(200,200,200,0.4)
    &:before
      color: #666
    &.line-numbers-mode
      .highlight-lines .highlighted
        &:before
          background-color rgba(200,200,200,0.4)
      &:after
        border-right 1px solid rgb(236,236,204)
  // 折叠代码块颜色
  .code-copy
    fill: #666
  .expand
    color: #666
  // 代码``颜色
  .theme-vdoing-content
    code
      background-color: rgba(255,225,225,0.5)
      color: #ff0000
  
  // 代码组
  .code-group-nav
    background: rgb(236,236,204)
    .code-group-nav-tab:hover
      background: #fbfbee
    .code-group-nav-tab.active
      background: #FCFFE7
      border: none
    .code-group-nav-tab.active:before
      background: radial-gradient(12px at left top, transparent 50%, #FCFFE7 50%)
    .code-group-nav-tab.active:after
      background: radial-gradient(12px at right top, transparent 50%, #FCFFE7 50%)

  // vuepress-plugin-tabs 插件的背景色
  .tabs-component-tab,
  .tabs-component-panels
    background-color rgba(255,255,255,0.6)
    border none

// 顶部进度条插件
$readingBgColor = transparent
$readingZIndex = 1000
$readingSize = 3px
$readingProgressColor = #b160ea
$readingProgressImage = none